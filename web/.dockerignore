# Ignore git directory.
/.git/
/.gitignore

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore logs and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage contents. Production storage is mounted as a persistent volume.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore generated frontend assets.
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Keep deployment config out of the image.
/config/deploy*.yml
/.kamal

# Ignore development and Docker metadata.
/.devcontainer
/.dockerignore
/Dockerfile*
.DS_Store
