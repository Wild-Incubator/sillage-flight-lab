# Local environment
.env*
!.env.example
!.env.deploy.local.example

# Kamal local deployment environment
/.kamal/secrets
/.kamal/secrets.*
!/.kamal/secrets.example
/.kamal/deploy.env

# Rails credentials key
/config/master.key

# Databases and local runtime state
/storage/*
!/storage/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids/
/tmp/pids/*
!/tmp/pids/.keep
/log/*
!/log/.keep

# Dependencies and generated assets
/node_modules/
/vendor/bundle/
/public/assets/

# OS/editor noise
.DS_Store
*.swp
