<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "exopter_design_system", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <%= link_to root_path, class: "brand" do %>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-copy">
          <span class="brand-name"><%= t("app.name") %></span>
          <span class="brand-system"><%= t("app.tagline") %></span>
        </span>
      <% end %>

      <nav class="main-nav" aria-label="<%= t("nav.primary") %>">
        <%= link_to t("nav.dashboard"), root_path %>
        <%= link_to t("nav.jumps"), jumps_path %>
        <%= link_to t("nav.import"), new_flight_import_path %>
        <%= link_to t("nav.design_system"), devreference_design_system_path %>
      </nav>
    </header>

    <main class="app-shell">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
