<% content_for :title, t("dashboard.title") %>

<section class="page-heading">
  <div>
    <p class="eyebrow"><%= t("dashboard.eyebrow") %></p>
    <h1><%= t("dashboard.title") %></h1>
  </div>
  <%= link_to t("dashboard.all_jumps"), jumps_path, class: "secondary-button" %>
</section>

<section class="flight-readiness-strip" aria-label="<%= t("flight_lab.readiness_label") %>">
  <div>
    <span><%= t("flight_lab.mode") %></span>
    <strong><%= t("flight_lab.mode_gld") %></strong>
  </div>
  <div>
    <span><%= t("flight_lab.fdr") %></span>
    <strong><%= t("flight_lab.fdr_ready") %></strong>
  </div>
  <div>
    <span><%= t("flight_lab.trace_source") %></span>
    <strong><%= t("flight_lab.source_flysight") %></strong>
  </div>
  <div>
    <span><%= t("flight_lab.analysis") %></span>
    <strong><%= t("flight_lab.analysis_ready") %></strong>
  </div>
</section>

<section class="dashboard-grid">
  <div class="tool-panel import-panel">
    <h2><%= t("imports.new.title") %></h2>
    <%= render "shared/upload_form" %>
  </div>

  <div class="stats-panel">
    <div class="stat">
      <span><%= t("stats.jumps") %></span>
      <strong><%= @stats[:jumps_count] %></strong>
    </div>
    <div class="stat">
      <span><%= t("stats.imports") %></span>
      <strong><%= @stats[:imports_count] %></strong>
    </div>
    <div class="stat">
      <span><%= t("stats.distance") %></span>
      <strong><%= meters(@stats[:total_distance_m]) %></strong>
    </div>
    <div class="stat">
      <span><%= t("stats.duration") %></span>
      <strong><%= duration(@stats[:total_duration_seconds]) %></strong>
    </div>
  </div>
</section>

<section class="content-split">
  <div>
    <div class="section-header">
      <h2><%= t("dashboard.recent_jumps") %></h2>
    </div>
    <%= render "jumps/list", jumps: @jumps %>
  </div>

  <aside class="tool-panel">
    <h2><%= t("dashboard.recent_imports") %></h2>
    <% if @flight_imports.any? %>
      <div class="import-list">
        <% @flight_imports.each do |flight_import| %>
          <%= link_to flight_import, class: "import-row" do %>
            <span><%= flight_import.source_filename %></span>
            <strong class="status <%= flight_import.status %>"><%= t("imports.status.#{flight_import.status}") %></strong>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state"><%= t("dashboard.no_imports") %></p>
    <% end %>
  </aside>
</section>
